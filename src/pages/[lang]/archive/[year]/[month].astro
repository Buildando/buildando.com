---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostCard from "../../../../components/PostCard.astro";
import { getArchive, type Post } from "../../../../lib/posts";
import { locales, useTranslations, localizedPath, localeMeta } from "../../../../i18n";

// One page per month that has posts, per locale (REQ-041).
export const getStaticPaths = (async () => {
  const paths = [];
  for (const lang of locales) {
    const archive = await getArchive(lang);
    for (const [year, months] of archive) {
      for (const [month, posts] of months) {
        paths.push({
          params: { lang, year: String(year), month: String(month).padStart(2, "0") },
          props: { posts },
        });
      }
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { lang, year, month } = Astro.params;
const { posts } = Astro.props as { posts: Post[] };
const t = useTranslations(lang);

// Localized "July 2026" / "Julho de 2026" (UTC to match the stored dates).
const title = new Intl.DateTimeFormat(localeMeta(lang).htmlLang, {
  month: "long",
  year: "numeric",
  timeZone: "UTC",
}).format(new Date(Date.UTC(Number(year), Number(month) - 1, 1)));
const heading = title.charAt(0).toUpperCase() + title.slice(1);
---

<BaseLayout
  title={heading}
  description={heading}
  path={localizedPath(lang, `/archive/${year}/${month}/`)}
  lang={lang}
>
  <h1>{heading}</h1>
  <p><a href={localizedPath(lang, "/archive/")}>{t("archive.all")}</a></p>
  {posts.map((post) => <PostCard post={post} />)}
</BaseLayout>
