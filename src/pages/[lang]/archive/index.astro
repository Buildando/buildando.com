---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getArchive } from "../../../lib/posts";
import {
  locales,
  useTranslations,
  localizedPath,
  hreflangAlternates,
  localeMeta,
} from "../../../i18n";

// Archive index (REQ-041): the year → month tree with post counts.
export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const archive = await getArchive(lang);
const years = [...archive.keys()].sort((a, b) => b - a);

const htmlLang = localeMeta(lang).htmlLang;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const monthName = (m: number) =>
  cap(
    new Intl.DateTimeFormat(htmlLang, { month: "long" }).format(
      new Date(2000, m - 1, 1),
    ),
  );
const pad = (m: number) => String(m).padStart(2, "0");
---

<BaseLayout
  title={t("archive.title")}
  description={t("archive.title")}
  path={localizedPath(lang, "/archive")}
  lang={lang}
  alternates={hreflangAlternates("/archive")}
>
  <h1>{t("archive.title")}</h1>
  {years.length === 0 && <p>{t("home.empty")}</p>}
  {
    years.map((year) => {
      const months = [...archive.get(year)!.keys()].sort((a, b) => b - a);
      return (
        <section class="archive-year">
          <h2>{year}</h2>
          <ul>
            {months.map((m) => (
              <li>
                <a href={localizedPath(lang, `/archive/${year}/${pad(m)}/`)}>
                  {monthName(m)}
                  <span>({archive.get(year)!.get(m)!.length})</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }
</BaseLayout>

<style>
  .archive-year {
    margin-top: 2rem;
  }
  .archive-year h2 {
    font-size: 1.1rem;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
  }
  .archive-year ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }
  .archive-year a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
  }
  .archive-year a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .archive-year span {
    color: var(--color-muted);
    font-size: 0.8rem;
  }
</style>
