---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { SITE } from "../../config/site";
import { getPublishedPosts } from "../../lib/posts";
import {
  locales,
  useTranslations,
  localizedPath,
  hreflangAlternates,
  siteDescription,
} from "../../i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

// Free-form home hero from markdown (REQ-034), one entry per locale, with a
// graceful fallback to the site name + localized description if none exists.
const hero = await getEntry("home", lang);
const HeroContent = hero ? (await hero.render()).Content : null;

const description = hero?.data.description ?? siteDescription(lang);
const title = hero?.data.title ?? SITE.name;
const posts = await getPublishedPosts(lang);
---

<BaseLayout
  title={title}
  description={description}
  path={localizedPath(lang, "/")}
  lang={lang}
  alternates={hreflangAlternates("/")}
>
  <section class="hero">
    {
      HeroContent ? (
        <HeroContent />
      ) : (
        <>
          <h1>{SITE.name}</h1>
          <p>{description}</p>
        </>
      )
    }
  </section>

  <h2 class="section-title">{t("home.latest")}</h2>
  {posts.length === 0 && <p>{t("home.empty")}</p>}
  {posts.map((post) => <PostCard post={post} />)}
</BaseLayout>

<style>
  /* The original hero styling, scoped to this quadrant only and applied to the
     markdown-rendered content (or the fallback name + description). */
  .hero {
    padding: 2rem 0 1rem;
  }
  .hero :global(h1) {
    margin: 0; /* cancel the global heading top-margin so the hero stays tight */
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: linear-gradient(120deg, var(--color-text), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero :global(p) {
    color: var(--color-muted);
    font-size: 1.15rem;
    max-width: 34rem;
    margin: 0.5rem 0 0;
  }
  .section-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-top: 2.5rem;
  }
</style>
