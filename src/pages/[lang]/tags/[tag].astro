---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { getTags } from "../../../lib/posts";
import { locales, useTranslations, localizedPath } from "../../../i18n";

// One listing page per distinct tag, per locale (REQ-019, REQ-032).
export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const tags = await getTags(lang);
    for (const [tag, posts] of tags) {
      paths.push({ params: { lang, tag }, props: { posts } });
    }
  }
  return paths;
}

const { lang, tag } = Astro.params;
const { posts } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout
  title={`#${tag}`}
  description={`${t("tags.for")} #${tag}`}
  path={localizedPath(lang, `/tags/${tag}/`)}
  lang={lang}
>
  <h1>#{tag}</h1>
  <p><a href={localizedPath(lang, "/tags/")}>{t("tags.all")}</a></p>
  {posts.map((post) => <PostCard post={post} />)}
</BaseLayout>
