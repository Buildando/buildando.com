---
import type { GetStaticPaths, Page } from "astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostCard from "../../../../components/PostCard.astro";
import Pagination from "../../../../components/Pagination.astro";
import { getCategories, type Post } from "../../../../lib/posts";
import { POSTS_PER_PAGE } from "../../../../config/site";
import { locales, useTranslations, localizedPath } from "../../../../i18n";

// One paginated listing per distinct category, per locale (REQ-019, REQ-037).
export const getStaticPaths = (async ({ paginate }) => {
  const paths = [];
  for (const lang of locales) {
    const categories = await getCategories(lang);
    for (const [category, posts] of categories) {
      const pageSize =
        POSTS_PER_PAGE > 0 ? POSTS_PER_PAGE : Math.max(posts.length, 1);
      paths.push(...paginate(posts, { params: { lang, category }, pageSize }));
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { lang, category } = Astro.params;
const page = Astro.props.page as Page<Post>;
const t = useTranslations(lang);
const path = page.url.current ?? localizedPath(lang, `/categories/${category}/`);
---

<BaseLayout
  title={category}
  description={`${t("category.for")} ${category}`}
  path={path}
  lang={lang}
>
  <h1>{category}</h1>
  {page.data.map((post) => <PostCard post={post} />)}
  <Pagination page={page} lang={lang} />
</BaseLayout>
