---
import type { GetStaticPaths, Page } from "astro";
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { SITE, POSTS_PER_PAGE } from "../../config/site";
import { absoluteUrl } from "../../lib/seo";
import {
  getPublishedPosts,
  getCategories,
  getTags,
  getArchive,
  type Post,
} from "../../lib/posts";
import {
  locales,
  useTranslations,
  localizedPath,
  hreflangAlternates,
  siteDescription,
  localeMeta,
} from "../../i18n";

// Static pagination (REQ-037). Page size 0 => one page with every post (keeps
// the facet filter). Positive => numbered, crawlable pages.
export const getStaticPaths = (async ({ paginate }) => {
  const paths = [];
  for (const lang of locales) {
    const posts = await getPublishedPosts(lang);
    const pageSize = POSTS_PER_PAGE > 0 ? POSTS_PER_PAGE : Math.max(posts.length, 1);
    paths.push(...paginate(posts, { params: { lang }, pageSize }));
  }
  return paths;
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const page = Astro.props.page as Page<Post>;
const t = useTranslations(lang);

const isFirst = page.currentPage === 1;
// The facet filter needs every card in the DOM, so it shows only when the whole
// listing fits on one page (REQ-035, REQ-037).
const showFilter = page.lastPage === 1;

// Free-form home hero from markdown (REQ-034), first page only.
const hero = isFirst ? await getEntry("home", lang) : null;
const HeroContent = hero ? (await hero.render()).Content : null;
const description = hero?.data.description ?? siteDescription(lang);
const title = hero?.data.title ?? SITE.name;

// Facet values, only when the filter shows: category and tag chips, and month
// chips (YYYY-MM) with localized labels, newest first (REQ-035).
let categories: string[] = [];
let tags: string[] = [];
let monthFacets: { value: string; label: string }[] = [];
if (showFilter) {
  categories = [...(await getCategories(lang)).keys()].sort();
  tags = [...(await getTags(lang)).keys()].sort();
  const shortFmt = new Intl.DateTimeFormat(localeMeta(lang).htmlLang, {
    month: "short",
    timeZone: "UTC",
  });
  const monthLabel = (year: number, m: number) => {
    const s = shortFmt.format(new Date(Date.UTC(year, m - 1, 1))).replace(".", "");
    return `${s.charAt(0).toUpperCase() + s.slice(1)} ${year}`;
  };
  for (const [year, mmap] of await getArchive(lang)) {
    for (const m of mmap.keys()) {
      monthFacets.push({
        value: `${year}-${String(m).padStart(2, "0")}`,
        label: monthLabel(year, m),
      });
    }
  }
  monthFacets.sort((a, b) => (a.value < b.value ? 1 : -1)); // newest first
}
const hasFacets =
  showFilter &&
  (categories.length > 0 || tags.length > 0 || monthFacets.length > 0);
const path = page.url.current ?? localizedPath(lang, "/");
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  lang={lang}
  alternates={isFirst ? hreflangAlternates("/") : []}
  prev={page.url.prev ? absoluteUrl(page.url.prev) : undefined}
  next={page.url.next ? absoluteUrl(page.url.next) : undefined}
>
  {
    isFirst && (
      <section class="hero">
        {HeroContent ? (
          <HeroContent />
        ) : (
          <>
            <h1>{SITE.name}</h1>
            <p>{description}</p>
          </>
        )}
      </section>
    )
  }

  <h2 class="section-title">{t("home.latest")}</h2>

  {/* Faceted filter (REQ-035). Hidden without JS — the full list shows. */}
  {
    hasFacets && (
      <div class="filter-bar" id="filter-bar" hidden>
        {categories.length > 0 && (
          <div class="facet" data-facet>
            <span class="facet-label">{t("filter.categories")}</span>
            {categories.map((c) => (
              <button class="chip" type="button" data-filter="category" data-value={c} aria-pressed="false">
                {c}
              </button>
            ))}
            <button class="chip more" type="button" data-more data-more-label={t("filter.more")} data-less-label={t("filter.less")} aria-expanded="false" hidden />
          </div>
        )}
        {tags.length > 0 && (
          <div class="facet" data-facet>
            <span class="facet-label">{t("filter.tags")}</span>
            {tags.map((tg) => (
              <button class="chip" type="button" data-filter="tag" data-value={tg} aria-pressed="false">
                #{tg}
              </button>
            ))}
            <button class="chip more" type="button" data-more data-more-label={t("filter.more")} data-less-label={t("filter.less")} aria-expanded="false" hidden />
          </div>
        )}
        {monthFacets.length > 0 && (
          <div class="facet" data-facet>
            <span class="facet-label">{t("filter.date")}</span>
            {monthFacets.map((mf) => (
              <button class="chip" type="button" data-filter="month" data-value={mf.value} aria-pressed="false">
                {mf.label}
              </button>
            ))}
            <button class="chip more" type="button" data-more data-more-label={t("filter.more")} data-less-label={t("filter.less")} aria-expanded="false" hidden />
          </div>
        )}
        <button class="chip clear" type="button" id="filter-clear" hidden>{t("filter.clear")}</button>
      </div>
    )
  }

  <div id="post-list">
    {page.data.length === 0 && <p>{t("home.empty")}</p>}
    {page.data.map((post) => <PostCard post={post} />)}
  </div>
  {showFilter && <p id="filter-empty" class="filter-empty" hidden>{t("filter.empty")}</p>}

  <Pagination page={page} lang={lang} />
</BaseLayout>

<script>
  import {
    matchesFilter,
    readFilter,
    writeFilter,
    toggle,
    isEmpty,
    type FilterCriteria,
  } from "../../lib/facet-filter";

  const bar = document.getElementById("filter-bar");
  const list = document.getElementById("post-list");
  if (bar && list) {
    bar.hidden = false; // reveal only when JS is available (progressive enhancement)
    const cards = Array.from(list.querySelectorAll<HTMLElement>(".card"));
    const empty = document.getElementById("filter-empty");
    const clearBtn = document.getElementById("filter-clear");

    let criteria: FilterCriteria = readFilter(new URLSearchParams(location.search));

    // "Show more": collapse each facet to this many chips until expanded.
    const FACET_LIMIT = 12;
    const collapseRefreshers: Array<() => void> = [];

    const setOf = (type: string): string[] =>
      type === "category"
        ? criteria.categories
        : type === "tag"
          ? criteria.tags
          : criteria.months;

    const syncChips = () => {
      bar.querySelectorAll<HTMLElement>(".chip[data-filter]").forEach((chip) => {
        const val = chip.dataset.value ?? "";
        chip.setAttribute(
          "aria-pressed",
          setOf(chip.dataset.filter ?? "").includes(val) ? "true" : "false",
        );
      });
      if (clearBtn) clearBtn.hidden = isEmpty(criteria);
      collapseRefreshers.forEach((fn) => fn());
    };

    const apply = () => {
      let shown = 0;
      for (const card of cards) {
        const meta = {
          category: card.dataset.category || undefined,
          tags: (card.dataset.tags ?? "").split(",").filter(Boolean),
          date: card.dataset.date ?? "",
        };
        const ok = matchesFilter(meta, criteria);
        card.hidden = !ok;
        if (ok) shown++;
      }
      if (empty) empty.hidden = shown !== 0;
      history.replaceState(null, "", location.pathname + writeFilter(criteria));
    };

    bar.addEventListener("click", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>(".chip[data-filter]");
      if (!chip) return;
      const val = chip.dataset.value ?? "";
      const type = chip.dataset.filter;
      if (type === "category") criteria.categories = toggle(criteria.categories, val);
      else if (type === "tag") criteria.tags = toggle(criteria.tags, val);
      else if (type === "month") criteria.months = toggle(criteria.months, val);
      syncChips();
      apply();
    });

    clearBtn?.addEventListener("click", () => {
      criteria = { categories: [], tags: [], months: [] };
      syncChips();
      apply();
    });

    // "Show more" per facet: collapse to FACET_LIMIT chips, keeping active chips.
    bar.querySelectorAll<HTMLElement>("[data-facet]").forEach((facet) => {
      const chips = Array.from(facet.querySelectorAll<HTMLElement>(".chip[data-filter]"));
      const moreBtn = facet.querySelector<HTMLElement>("[data-more]");
      if (!moreBtn || chips.length <= FACET_LIMIT) return;
      const hiddenCount = chips.length - FACET_LIMIT;
      let expanded = false;
      const refresh = () => {
        chips.forEach((chip, i) => {
          const pressed = chip.getAttribute("aria-pressed") === "true";
          chip.hidden = !expanded && i >= FACET_LIMIT && !pressed;
        });
        moreBtn.textContent = expanded
          ? moreBtn.dataset.lessLabel ?? "Show less"
          : (moreBtn.dataset.moreLabel ?? "Show more (+{n})").replace(
              "{n}",
              String(hiddenCount),
            );
        moreBtn.setAttribute("aria-expanded", expanded ? "true" : "false");
      };
      moreBtn.hidden = false;
      moreBtn.addEventListener("click", () => {
        expanded = !expanded;
        refresh();
      });
      collapseRefreshers.push(refresh);
      refresh();
    });

    syncChips();
    apply();
  }
</script>

<style>
  /* The original hero styling, scoped to this quadrant only. */
  .hero {
    padding: 2rem 0 1rem;
  }
  .hero :global(h1) {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: linear-gradient(120deg, var(--color-text), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero :global(p) {
    color: var(--color-muted);
    font-size: 1.15rem;
    max-width: 34rem;
    margin: 0.5rem 0 0;
  }
  .section-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-top: 2.5rem;
    margin-bottom: 0;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    margin: 0.75rem 0 2.25rem;
    padding: 0.9rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  .facet {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .facet-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 0.1rem;
  }
  #post-list {
    border-top: 1px solid var(--color-border);
    margin-top: 0.75rem;
  }
  .chip {
    font: inherit;
    font-size: 0.85rem;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    line-height: 1.4;
  }
  .chip:hover {
    border-color: var(--color-accent);
  }
  .chip[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-contrast);
  }
  .chip.clear {
    color: var(--color-muted);
  }
  .chip.more {
    color: var(--color-accent);
    border-color: transparent;
    font-weight: 600;
  }
  .chip.more:hover {
    border-color: var(--color-accent);
  }
  .filter-empty {
    color: var(--color-muted);
    padding: 1.5rem 0;
  }
</style>
