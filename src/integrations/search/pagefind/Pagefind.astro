---
// Search adapter — Pagefind (REQ-020, REQ-021). Renders a mount element and
// initializes the Pagefind UI into it: lazily when the mount first becomes
// visible (so the modal loads it on open and the /search page on load), and also
// on demand via a registered init (the modal calls it). The build-time index is
// produced by `pagefind --site dist` in the package.json build script.
// Selected by INTEGRATIONS.search === "pagefind".
import { useTranslations } from "../../../i18n";

interface Props {
  /** Unique id of the mount element (the modal and the page pass different ids). */
  id: string;
  lang: string;
}
const { id, lang } = Astro.props;
const t = useTranslations(lang);

const idJson = JSON.stringify(id);
const script = `(function(){
  var el = document.getElementById(${idJson});
  if (!el) return;
  function init(){
    if (el.dataset.ready) return;
    el.dataset.ready = "1";
    var css = document.createElement("link");
    css.rel = "stylesheet"; css.href = "/pagefind/pagefind-ui.css";
    document.head.appendChild(css);
    import("/pagefind/pagefind-ui.js").then(function(){
      new PagefindUI({ element: "#" + ${idJson}, showSubResults: true, showImages: false,
        translations: { placeholder: el.dataset.lang === "en" ? "Search" : "Buscar" } });
      var input = el.querySelector("input"); if (input) setTimeout(function(){ input.focus(); }, 0);
    }).catch(function(){
      el.innerHTML = '<p style="color:var(--color-muted)">' + (el.dataset.building || "") + "</p>";
    });
  }
  (window.__searchInit = window.__searchInit || {})[${idJson}] = init;
  var io = new IntersectionObserver(function(entries){
    if (entries.some(function(e){ return e.isIntersecting; })){ init(); io.disconnect(); }
  });
  io.observe(el);
})();`;
---

<div id={id} data-lang={lang} data-building={t("search.building")}></div>
<script is:inline set:html={script} />
