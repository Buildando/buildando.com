---
// Comments adapter — giscus (GitHub Discussions), REQ-022–REQ-024. Self-contained:
// renders the whole section, or nothing when not configured (empty
// repoId/categoryId → no heading, no script, REQ-017). Loaded lazily on scroll.
// Selected by INTEGRATIONS.comments === "giscus".
import { GISCUS } from "../../../config/site";
import { useTranslations } from "../../../i18n";

interface Props {
  /** Per-post mapping override (REQ-024); falls back to the configured mapping. */
  term?: string;
  lang: string;
}
const { term, lang } = Astro.props;
const t = useTranslations(lang);
const configured = Boolean(GISCUS.repoId && GISCUS.categoryId);

// Lazy loader as a raw string (set:html avoids HTML-escaping the JS operators).
const loader = `(function(){
  var mount = document.getElementById("giscus-mount");
  if (!mount || mount.dataset.loaded) return;
  function load(){
    if (mount.dataset.loaded) return;
    mount.dataset.loaded = "true";
    var d = mount.dataset;
    var s = document.createElement("script");
    s.src = "https://giscus.app/client.js";
    s.async = true;
    s.crossOrigin = "anonymous";
    s.setAttribute("data-repo", d.repo);
    s.setAttribute("data-repo-id", d.repoid);
    s.setAttribute("data-category", d.category);
    s.setAttribute("data-category-id", d.categoryid);
    s.setAttribute("data-mapping", d.mapping);
    if (d.term) s.setAttribute("data-term", d.term);
    s.setAttribute("data-reactions-enabled", d.reactions);
    s.setAttribute("data-emit-metadata", "0");
    s.setAttribute("data-theme", d.theme);
    s.setAttribute("data-lang", d.lang);
    mount.appendChild(s);
  }
  var io = new IntersectionObserver(function(entries){
    for (var i = 0; i < entries.length; i++){
      if (entries[i].isIntersecting){ load(); io.disconnect(); return; }
    }
  });
  io.observe(mount);
})();`;
---

{
  configured && (
    <section class="discussion" aria-label={t("post.comments")}>
      <h2>{t("post.comments")}</h2>
      <div
        id="giscus-mount"
        data-repo={GISCUS.repo}
        data-repoid={GISCUS.repoId}
        data-category={GISCUS.category}
        data-categoryid={GISCUS.categoryId}
        data-mapping={term ? "specific" : GISCUS.mapping}
        data-term={term ?? ""}
        data-reactions={GISCUS.reactionsEnabled}
        data-theme={GISCUS.theme}
        data-lang={lang}
      />
      <script is:inline set:html={loader} />
    </section>
  )
}

<style>
  .discussion {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
