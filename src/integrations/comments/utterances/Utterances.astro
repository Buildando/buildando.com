---
// Comments adapter — utterances (GitHub Issues), https://utteranc.es. Same shape
// as the giscus adapter: self-contained, renders nothing when `repo` is empty,
// loaded lazily on scroll. Selected by INTEGRATIONS.comments === "utterances".
import { UTTERANCES } from "../../../config/site";
import { useTranslations } from "../../../i18n";

interface Props {
  /** Per-post issue-term override; falls back to the configured issueTerm. */
  term?: string;
  lang: string;
}
const { term, lang } = Astro.props;
const t = useTranslations(lang);
const configured = Boolean(UTTERANCES.repo);

const loader = `(function(){
  var mount = document.getElementById("utterances-mount");
  if (!mount || mount.dataset.loaded) return;
  function load(){
    if (mount.dataset.loaded) return;
    mount.dataset.loaded = "true";
    var d = mount.dataset;
    var s = document.createElement("script");
    s.src = "https://utteranc.es/client.js";
    s.async = true;
    s.crossOrigin = "anonymous";
    s.setAttribute("repo", d.repo);
    s.setAttribute("issue-term", d.term);
    if (d.label) s.setAttribute("label", d.label);
    s.setAttribute("theme", d.theme);
    mount.appendChild(s);
  }
  var io = new IntersectionObserver(function(entries){
    for (var i = 0; i < entries.length; i++){
      if (entries[i].isIntersecting){ load(); io.disconnect(); return; }
    }
  });
  io.observe(mount);
})();`;
---

{
  configured && (
    <section class="discussion" aria-label={t("post.comments")}>
      <h2>{t("post.comments")}</h2>
      <div
        id="utterances-mount"
        data-repo={UTTERANCES.repo}
        data-term={term ?? UTTERANCES.issueTerm}
        data-label={UTTERANCES.label}
        data-theme={UTTERANCES.theme}
      />
      <script is:inline set:html={loader} />
    </section>
  )
}

<style>
  .discussion {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
