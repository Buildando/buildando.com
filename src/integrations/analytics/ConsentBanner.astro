---
// Cookie consent coordinator (REQ-042), provider-agnostic. Cookie-setting
// adapters (GA, AdSense, …) register a loader on `window.__consentLoaders`; this
// runs them only after the reader accepts — or immediately when consent is not
// required. `gated` (from the Analytics port) says whether any such provider is
// configured; when false, nothing renders, so the default build stays clean.
import { CONSENT } from "../../config/site";
import { useTranslations } from "../../i18n";

interface Props {
  lang: string;
  gated: boolean;
}
const { lang, gated } = Astro.props;
const t = useTranslations(lang);

const consentScript = `(function(){
  function runAll(){ (window.__consentLoaders||[]).forEach(function(fn){ try{fn();}catch(e){} }); }
  var required=${CONSENT.required ? "true" : "false"};
  var decision=null; try{ decision=localStorage.getItem("consent"); }catch(e){}
  if(!required){ runAll(); return; }
  if(decision==="granted"){ runAll(); return; }
  if(decision==="denied"){ return; }
  var banner=document.getElementById("consent-banner");
  if(!banner) return;
  banner.hidden=false;
  function decide(v){ try{ localStorage.setItem("consent", v); }catch(e){} banner.hidden=true; if(v==="granted") runAll(); }
  var a=document.getElementById("consent-accept"), r=document.getElementById("consent-reject");
  if(a) a.addEventListener("click", function(){ decide("granted"); });
  if(r) r.addEventListener("click", function(){ decide("denied"); });
})();`;
---

{
  gated && (
    <>
      {CONSENT.required && (
        <div id="consent-banner" class="consent" role="dialog" aria-label={t("consent.title")} hidden>
          <p class="consent-text">
            {t("consent.text")}
            {CONSENT.privacyUrl && (
              <>
                {" "}
                <a href={CONSENT.privacyUrl}>{t("consent.privacy")}</a>
              </>
            )}
          </p>
          <div class="consent-actions">
            <button id="consent-reject" type="button" class="consent-btn">
              {t("consent.reject")}
            </button>
            <button id="consent-accept" type="button" class="consent-btn consent-accept">
              {t("consent.accept")}
            </button>
          </div>
        </div>
      )}
      <script is:inline set:html={consentScript} />
    </>
  )
}

<style>
  .consent {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    max-width: 44rem;
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }
  .consent-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
    flex: 1 1 16rem;
  }
  .consent-actions {
    display: flex;
    gap: 0.5rem;
  }
  .consent-btn {
    font: inherit;
    font-size: 0.9rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
  }
  .consent-btn:hover {
    border-color: var(--color-accent);
  }
  .consent-accept {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-weight: 600;
  }
</style>
