---
// In-layout search (REQ-036): a modal opened by the header icon, by "/" or by
// Ctrl/Cmd+K. Reuses the Pagefind index (REQ-020), loaded lazily on first open.
// Without JS, the header trigger is a plain link to /{lang}/search.
import { useTranslations } from "../i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<dialog id="search-dialog" class="search-dialog" aria-label={t("search.open")}>
  <div class="search-dialog-inner">
    <div
      id="search-modal-mount"
      data-lang={lang}
      data-building={t("search.building")}
    >
    </div>
  </div>
</dialog>

<script is:inline>
  (function () {
    var dialog = document.getElementById("search-dialog");
    if (!dialog || typeof dialog.showModal !== "function") return;
    var mount = document.getElementById("search-modal-mount");
    var loaded = false;

    function ensure() {
      if (loaded) return;
      loaded = true;
      var css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(css);
      import("/pagefind/pagefind-ui.js")
        .then(function () {
          new PagefindUI({
            element: "#search-modal-mount",
            showSubResults: true,
            showImages: false,
            translations: {
              placeholder: mount.dataset.lang === "en" ? "Search" : "Buscar",
            },
          });
        })
        .catch(function () {
          mount.innerHTML =
            '<p style="color:var(--color-muted)">' +
            (mount.dataset.building || "") +
            "</p>";
        });
    }

    function open() {
      if (dialog.open) return;
      dialog.showModal();
      ensure();
      setTimeout(function () {
        var input = dialog.querySelector("input");
        if (input) input.focus();
      }, 0);
    }

    var triggers = document.querySelectorAll(".search-trigger");
    for (var i = 0; i < triggers.length; i++) {
      triggers[i].addEventListener("click", function (e) {
        e.preventDefault();
        open();
      });
    }

    document.addEventListener("keydown", function (e) {
      var el = e.target;
      var typing =
        el &&
        (/^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName) || el.isContentEditable);
      var slash = e.key === "/" && !typing;
      var cmdK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k";
      if (slash || cmdK) {
        e.preventDefault();
        open();
      }
    });

    // Click on the backdrop closes.
    dialog.addEventListener("click", function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>

<style>
  .search-dialog {
    margin: 10vh auto auto;
    width: min(92vw, 640px);
    max-height: 72vh;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }
  .search-dialog-inner {
    padding: 1rem;
    max-height: 72vh;
    overflow-y: auto;
  }
</style>
