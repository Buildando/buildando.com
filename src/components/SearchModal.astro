---
// In-layout search shell (REQ-036): a modal opened by the header icon, by "/" or
// by Ctrl/Cmd+K. Provider-agnostic — it hosts the Search port and just triggers
// its init on open. Without JS, the header trigger is a plain link to /{lang}/search.
import { useTranslations } from "../i18n";
import Search from "../integrations/Search.astro";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<dialog id="search-dialog" class="search-dialog" aria-label={t("search.open")}>
  <div class="search-dialog-inner">
    <Search id="search-modal-mount" lang={lang} />
  </div>
</dialog>

<script is:inline>
  (function () {
    var dialog = document.getElementById("search-dialog");
    if (!dialog || typeof dialog.showModal !== "function") return;
    function open() {
      if (dialog.open) return;
      dialog.showModal();
      var fn = (window.__searchInit || {})["search-modal-mount"];
      if (fn) fn();
    }
    var triggers = document.querySelectorAll(".search-trigger");
    for (var i = 0; i < triggers.length; i++) {
      triggers[i].addEventListener("click", function (e) {
        e.preventDefault();
        open();
      });
    }
    document.addEventListener("keydown", function (e) {
      var el = e.target;
      var typing =
        el &&
        (/^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName) || el.isContentEditable);
      if (
        (e.key === "/" && !typing) ||
        ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k")
      ) {
        e.preventDefault();
        open();
      }
    });
    dialog.addEventListener("click", function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>

<style>
  .search-dialog {
    margin: 10vh auto auto;
    width: min(92vw, 640px);
    max-height: 72vh;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }
  .search-dialog-inner {
    padding: 1rem;
    max-height: 72vh;
    overflow-y: auto;
  }
</style>
