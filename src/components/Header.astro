---
import { SITE, NAV, THEME, I18N } from "../config/site";
import { useTranslations, localizedPath } from "../i18n";

interface Props {
  lang: string;
  /** Per-locale switcher targets (posts pass this to honor translations/fallback). */
  langSwitch?: Record<string, string>;
}
const { lang, langSwitch } = Astro.props;
const t = useTranslations(lang);

// Default switch target: preserve the sub-path, swap the leading locale segment.
const rest = "/" + Astro.url.pathname.split("/").slice(2).join("/");
const switchHref = (code: string) => langSwitch?.[code] ?? localizedPath(code, rest);
---

<header class="site-header">
  <div class="wrap">
    <a class="brand" href={localizedPath(lang, "/")}>
      <img src={SITE.logo} alt="" width="28" height="28" aria-hidden="true" />
      <span>{SITE.name}</span>
    </a>

    <nav aria-label="Principal">
      <ul>
        {
          NAV.map((item) => {
            const href = localizedPath(lang, item.path);
            return (
              <li>
                <a href={href} aria-current={Astro.url.pathname === href ? "page" : undefined}>
                  {t(item.key)}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="controls">
      <a
        class="search-trigger"
        href={localizedPath(lang, "/search")}
        aria-label={t("search.open")}
        title="Ctrl/⌘ + K"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <span class="kbd">⌘K</span>
      </a>
      {
        I18N.locales.length > 1 && (
          <div class="lang" role="group" aria-label={t("a11y.lang")}>
            {I18N.locales.map((l) => (
              <a
                href={switchHref(l.code)}
                hreflang={l.htmlLang}
                aria-current={l.code === lang ? "true" : undefined}
                lang={l.htmlLang}
              >
                {l.code.toUpperCase()}
              </a>
            ))}
          </div>
        )
      }
      {
        THEME.allowToggle && (
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label={t("a11y.theme")} title={t("a11y.theme")}>
            <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
            </svg>
            <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</header>

{
  THEME.allowToggle && (
    <script is:inline define:vars={{ def: THEME.default }}>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.dataset.theme || def;
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem("theme", next); } catch (e) {}
        });
      })();
    </script>
  )
}

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
  }
  .wrap {
    max-width: var(--content-width);
    margin-inline: auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-text);
    margin-right: auto;
  }
  nav ul {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--color-muted);
    text-decoration: none;
  }
  nav a[aria-current="page"],
  nav a:hover {
    color: var(--color-text);
  }
  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 34px;
    padding: 0 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-muted);
    text-decoration: none;
  }
  .search-trigger:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .search-trigger .kbd {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
  }
  @media (max-width: 640px) {
    .search-trigger .kbd {
      display: none;
    }
  }
  .lang {
    display: inline-flex;
    gap: 0.25rem;
    font-size: 0.8rem;
  }
  .lang a {
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.15rem 0.35rem;
    border-radius: 5px;
  }
  .lang a[aria-current="true"] {
    color: var(--color-accent-contrast);
    background: var(--color-accent);
  }
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
  }
  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  /* Show the icon for the theme you can switch TO. */
  .theme-toggle .moon {
    display: none;
  }
  .theme-toggle .sun {
    display: inline;
  }
  :root[data-theme="light"] .theme-toggle .sun {
    display: none;
  }
  :root[data-theme="light"] .theme-toggle .moon {
    display: inline;
  }
  @media (max-width: 640px) {
    .brand span {
      display: none;
    }
  }
</style>
