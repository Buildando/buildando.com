---
// Social share buttons (REQ-040). Static share-intent links (no JS) as duotone
// icon chips, plus an optional "copy link" button that appears only when the
// browser supports the clipboard. Config-driven; distinct from the OG image.
import { SHARE } from "../config/site";
import { useTranslations } from "../i18n";
import Icon from "./Icon.astro";

interface Props {
  /** Absolute canonical URL of the post. */
  url: string;
  title: string;
  lang: string;
}
const { url, title, lang } = Astro.props;
const t = useTranslations(lang);
const e = encodeURIComponent;

const intents: Record<string, { label: string; href: string }> = {
  x: { label: "X", href: `https://x.com/intent/tweet?text=${e(title)}&url=${e(url)}` },
  whatsapp: { label: "WhatsApp", href: `https://wa.me/?text=${e(`${title} ${url}`)}` },
  telegram: { label: "Telegram", href: `https://t.me/share/url?url=${e(url)}&text=${e(title)}` },
  linkedin: { label: "LinkedIn", href: `https://www.linkedin.com/sharing/share-offsite/?url=${e(url)}` },
  facebook: { label: "Facebook", href: `https://www.facebook.com/sharer/sharer.php?u=${e(url)}` },
};

const items = SHARE.networks
  .map((n) => (intents[n] ? { name: n, ...intents[n] } : null))
  .filter((i): i is { name: string; label: string; href: string } => i !== null);
const show = items.length > 0 || SHARE.copyLink;

const copyScript = `(function(){
  var btn = document.querySelector('.share-copy');
  if (!btn || !navigator.clipboard) return;
  btn.hidden = false;
  btn.addEventListener('click', function(){
    navigator.clipboard.writeText(btn.dataset.url).then(function(){
      btn.classList.add('copied');
      setTimeout(function(){ btn.classList.remove('copied'); }, 2000);
    });
  });
})();`;
---

{
  show && (
    <section class="share" aria-label={t("share.title")}>
      <span class="share-label">{t("share.title")}</span>
      <ul>
        {items.map((i) => (
          <li>
            <a class="icon-chip" href={i.href} target="_blank" rel="noopener" aria-label={i.label} title={i.label}>
              <Icon name={i.name} />
            </a>
          </li>
        ))}
        {SHARE.copyLink && (
          <li>
            <button class="icon-chip share-copy" type="button" data-url={url} aria-label={t("share.copy")} title={t("share.copy")} hidden>
              <svg class="ic-link" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 15 15 9" />
                <path d="M11 6l1-1a4 4 0 0 1 6 6l-1 1" />
                <path d="M13 18l-1 1a4 4 0 0 1-6-6l1-1" />
              </svg>
              <svg class="ic-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </button>
          </li>
        )}
      </ul>
      {SHARE.copyLink && <script is:inline set:html={copyScript} />}
    </section>
  )
}

<style>
  .share {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .share-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }
  .share ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .share-copy .ic-check {
    display: none;
  }
  .share-copy.copied {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-contrast);
  }
  .share-copy.copied .ic-link {
    display: none;
  }
  .share-copy.copied .ic-check {
    display: inline;
  }
</style>
