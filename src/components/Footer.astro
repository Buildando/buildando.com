---
import { SITE, SOCIAL } from "../config/site";
import { useTranslations, localizedPath } from "../i18n";
import Icon from "./Icon.astro";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <p>© {year} {SITE.author}</p>
    <ul class="social">
      {SOCIAL.map((s) => (
        <li>
          <a
            class="icon-chip"
            href={s.href}
            rel="me noopener"
            target="_blank"
            aria-label={s.label}
            title={s.label}
          >
            <Icon name={s.icon} />
          </a>
        </li>
      ))}
      <li>
        <a
          class="icon-chip"
          href={localizedPath(lang, "/rss.xml")}
          aria-label={t("footer.rss")}
          title={t("footer.rss")}
        >
          <Icon name="rss" />
        </a>
      </li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    color: var(--color-muted);
  }
  .wrap {
    max-width: var(--content-width);
    margin-inline: auto;
    padding: 1.5rem 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
