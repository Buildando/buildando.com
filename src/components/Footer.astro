---
import { SITE, SOCIAL } from "../config/site";
import { useTranslations, localizedPath } from "../i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <p>© {year} {SITE.author}</p>
    <ul>
      {SOCIAL.map((s) => (
        <li>
          <a href={s.href} rel="me noopener" target="_blank">{s.label}</a>
        </li>
      ))}
      <li><a href={localizedPath(lang, "/rss.xml")}>{t("footer.rss")}</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    color: var(--color-muted);
  }
  .wrap {
    max-width: var(--content-width);
    margin-inline: auto;
    padding: 1.5rem 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  ul {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  a {
    color: var(--color-muted);
  }
  a:hover {
    color: var(--color-text);
  }
</style>
