---
// Client-side full-text search (REQ-020, REQ-021). Pagefind builds a static
// index from the rendered HTML at build time (`pagefind --site dist`), and its
// UI runs entirely in the browser against static files — no backend.
// In `astro dev` the index does not exist yet; it appears after a build.
import { useTranslations } from "../i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div id="search" data-lang={lang} data-building={t("search.building")}></div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<!-- is:inline so Astro/Vite does not try to bundle-resolve the runtime-only
     Pagefind asset (it exists in dist/ only after `pagefind --site dist`). -->
<script is:inline>
  (async () => {
    var el = document.getElementById("search");
    try {
      await import("/pagefind/pagefind-ui.js");
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        translations: { placeholder: el.dataset.lang === "en" ? "Search" : "Buscar" },
      });
    } catch (e) {
      if (el)
        el.innerHTML =
          '<p style="color:var(--color-muted)">' + el.dataset.building + "</p>";
    }
  })();
</script>

<style is:global>
  :root {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-surface);
  }
</style>
