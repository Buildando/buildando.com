# Apache config for HostGator shared hosting. Shipped in the build output and
# deployed to public_html. Keep this minimal and test against the live host —
# .htaccess on shared Apache is powerful and easy to get subtly wrong.

# Force HTTPS + canonical host (HTTP -> HTTPS). Adjust the domain when forking.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/rss+xml
</IfModule>

# Caching: long for fingerprinted assets, short for HTML.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Astro emits fingerprinted files under /_astro/ — safe to cache immutably.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|svg|png|jpg|jpeg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

ErrorDocument 404 /404.html
